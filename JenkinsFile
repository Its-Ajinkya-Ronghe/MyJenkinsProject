pipeline {
    agent any

    tools {
        maven 'Maven3' 
        jdk 'JDK22'
    }

    stages {
        stage('Build') {
            steps {
                // Moving into the sub-folder and running the build
                bat 'mvn -f Excel_Sheet_Parallel_Testing/pom.xml clean compile'
            }
        }

        stage('Test') {
            steps {
                // Running tests from the specific module
                bat 'mvn -f Excel_Sheet_Parallel_Testing/pom.xml test'
            }
        }
    }

    post {
        always {
            // This runs regardless of build success or failure
            publishHTML(target: [
                allowMissing: false,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                // Path must include the sub-folder name
                reportDir: 'Excel_Sheet_Parallel_Testing/target/surefire-reports', 
                reportFiles: 'index.html', 
                reportName: 'Test Report'
            ])
        }
    }
}
